# Copy to .env.local for local dev. On Hostinger these go in
# hPanel -> your web app -> Environment variables (it can import this file
# directly). Never commit real values — .gitignore covers .env*.

# --- Contact form -----------------------------------------------------------
# Used by src/app/api/contact/route.js, which both the contact page and the
# services "Get in touch" form post to. Without SMTP_HOST / SMTP_USER /
# SMTP_PASS the route returns "Email service is not configured yet" and no mail
# is sent — so these are required for the forms to work at all.
SMTP_HOST=
# 465 uses TLS directly; 587 uses STARTTLS. The route picks based on this.
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Where enquiries land. Falls back to aqdaar.jamal@gmail.com when unset.
CONTACT_TO=
# The From header. Falls back to "Aqdaar Website <SMTP_USER>" when unset.
CONTACT_FROM=
